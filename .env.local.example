# ─────────────────────────────────────────────────────────────────
# Supabase – get these from https://supabase.com/dashboard/project/_/settings/api
# ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Server-only (never expose to the browser)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ─────────────────────────────────────────────────────────────────
# App
# ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# In production on Vercel, set this to: https://your-app.vercel.app

# ─────────────────────────────────────────────────────────────────
# Allowed email domain (no @, just the domain)
# ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_ALLOWED_DOMAIN=razorpay.com
